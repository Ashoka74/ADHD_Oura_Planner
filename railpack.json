{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": ["pip install --cache-dir=/opt/pip-cache fastmcp httpx uvicorn starlette"]
    }
  },
  "deploy": {
    "startCommand": "python server.py --http",
    "inputs": [
      {
        "step": "packages:mise",
        "include": [
          "/mise/shims",
          "/mise/installs",
          "/usr/local/bin/mise",
          "/etc/mise/config.toml",
          "/root/.local/state/mise"
        ]
      },
      {
        "step": "install",
        "include": ["."]
      },
      {
        "local": true,
        "include": ["."]
      }
    ],
    "variables": {
      "PYTHONUNBUFFERED": "1"
    }
  }
}
