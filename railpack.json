{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": ["pip install --target=/app/deps fastmcp httpx uvicorn starlette"]
    }
  },
  "deploy": {
    "startCommand": "PYTHONPATH=/app/deps python server.py --http"
  }
}
